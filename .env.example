# ---- Collector Identity ----
COLLECTOR_NAME=otelcol-custom
COLLECTOR_IMAGE_NAME=otelcol-custom
COLLECTOR_CONTAINER_NAME=otelcol-custom

# ---- Version Pins ----
GO_VERSION=1.25.8
OCB_VERSION=0.148.0
OTEL_CORE_VERSION=0.148.0
OTEL_CONTRIB_VERSION=0.148.0
OTEL_CONFMAP_VERSION=1.48.0

# ---- Components (comma-separated gomod paths, without version) ----
# Core modules (go.opentelemetry.io/...) use OTEL_CORE_VERSION automatically
# Contrib modules (github.com/.../contrib/...) use OTEL_CONTRIB_VERSION automatically
#
# Available receivers:  https://opentelemetry.io/ecosystem/registry/?language=collector&component=receiver
# Available processors: https://opentelemetry.io/ecosystem/registry/?language=collector&component=processor
# Available exporters:  https://opentelemetry.io/ecosystem/registry/?language=collector&component=exporter
# Available extensions: https://opentelemetry.io/ecosystem/registry/?language=collector&component=extension
OTEL_RECEIVERS=go.opentelemetry.io/collector/receiver/otlpreceiver
OTEL_PROCESSORS=go.opentelemetry.io/collector/processor/batchprocessor
OTEL_EXPORTERS=go.opentelemetry.io/collector/exporter/debugexporter,go.opentelemetry.io/collector/exporter/otlpexporter
OTEL_EXTENSIONS=github.com/open-telemetry/opentelemetry-collector-contrib/extension/healthcheckextension

# ---- Network Ports ----
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_HEALTH_PORT=13133

# ---- Collector Behavior ----
DEBUG_VERBOSITY=detailed

# ---- Docker Compose Project ----
COMPOSE_PROJECT_NAME=otel-custom-collector
