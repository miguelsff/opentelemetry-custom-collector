# ---- Collector Identity ----
COLLECTOR_NAME=otelcol-custom
COLLECTOR_IMAGE_NAME=otelcol-custom
COLLECTOR_CONTAINER_NAME=otelcol-custom

# ---- Version Pins ----
GO_VERSION=1.25.8
OCB_VERSION=0.148.0
OTEL_CORE_VERSION=0.148.0
OTEL_CONFMAP_VERSION=1.48.0

# ---- Network Ports ----
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_HEALTH_PORT=13133

# ---- Collector Behavior ----
DEBUG_VERBOSITY=detailed

# ---- Docker Compose Project ----
COMPOSE_PROJECT_NAME=otel-custom-collector
